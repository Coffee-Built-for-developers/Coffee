{
  "manifest_version": 3,
  "name": "Coffee",
  "version": "1.1.0",
  "description": "Privacy-first image uploads. Automatically strips EXIF/GPS metadata before any image leaves your browser.",

  "icons": {
    "16":  "assets/icons/icon16.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icons/icon16.png",
      "48":  "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Coffee – Strip Image Metadata"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/imageProcessor.js", "content/content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}
